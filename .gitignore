# 1. Системные файлы Python (тот самый мусор)
__pycache__/
*.py[cod]
*$py.class

# 2. Виртуальные окружения (чтобы не залить гигабайты библиотек)
venv/
env/
.env

# 3. Настройки редакторов кода (VS Code, PyCharm и др.)
.vscode/
.idea/
*.swp

# 4. Файлы операционных систем (Windows, macOS)
Thumbs.db
.DS_Store

# 5. Кэш Jupyter Notebook (если будете использовать)
.ipynb_checkpoints/

# 6. Данные и статистика (раскомментируйте, если не хотите случайно залить тяжелые файлы)
# *.csv
# *.dat
# *.log